    if (!checkDimensions(v1, v2)) {
        return;
    } else {
        for (var dim in v1) {
            if (v1.hasOwnProperty(dim) && v2.hasOwnProperty(dim)) {
                sum += v1[dim] * v2[dim];
            } else {
                console.warn(
                    "Vector dimension definitions  not match! Check dimension key names.",
                );
